{
    "manifest_version": 3,
    "name": "Pic Fit",
    "version": "1.0.2",
    "description": "Automatically scale and center standalone image.",
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"],
            "run_at": "document_end"
        }
    ],
    "icons": {
        "128": "icon-128.png"
    }
}
