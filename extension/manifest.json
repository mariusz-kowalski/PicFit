{
    "manifest_version": 3,
    "name": "Auto Image Fit",
    "version": "1.0",
    "description": "Automatically scale and center standalone images.",
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"],
            "run_at": "document_end"
        }
    ]
}
